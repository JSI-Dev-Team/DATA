# Copy this file to `.env.local` and fill in the values below.
# `.env.local` is gitignored and will not be committed.

# Web3Forms access key — used by the "Book Your Free Trial Class" form on /contact
# to email submissions to dynamicacademyofthearts@gmail.com.
#
# How to obtain (free, ~30 seconds):
#   1. Go to https://web3forms.com/
#   2. Enter dynamicacademyofthearts@gmail.com in the box on the homepage.
#   3. Web3Forms emails you an access key. Paste it on the line below.
#   4. Restart `npm run dev` so Vite picks up the new env var.
VITE_WEB3FORMS_ACCESS_KEY=
